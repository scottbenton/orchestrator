{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "claude",
          "cmd": "claude",
          "args": true,
          "sidecar": false
        },
        {
          "name": "sh",
          "cmd": "/bin/sh",
          "args": true,
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "which",
          "cmd": "which",
          "args": true,
          "sidecar": false
        },
        {
          "name": "tmux",
          "cmd": "tmux",
          "args": true,
          "sidecar": false
        }
      ]
    },
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "fs:default",
    {
      "identifier": "fs:write-all",
      "allow": [{ "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$HOME/**" }]
    },
    "sql:default",
    "sql:allow-execute",
    "store:default",
    "dialog:allow-open",
    "opener:default"
  ]
}
