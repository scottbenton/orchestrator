{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "fs:default",
    {
      "identifier": "fs:write-all",
      "allow": [{ "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$HOME/**" }]
    },
    "sql:default",
    "store:default",
    "dialog:allow-open",
    "opener:default"
  ]
}
